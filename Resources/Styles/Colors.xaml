<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary palette - warm terracotta -->
    <Color x:Key="Primary">#D94E34</Color>
    <Color x:Key="PrimaryDark">#B8381F</Color>
    <Color x:Key="PrimaryLight">#E8735C</Color>
    <Color x:Key="PrimaryVeryLight">#FEF0ED</Color>

    <!-- Secondary - fresh green -->
    <Color x:Key="Secondary">#059669</Color>
    <Color x:Key="SecondaryDark">#047857</Color>
    <Color x:Key="SecondaryVeryLight">#ECFDF5</Color>

    <!-- Accent -->
    <Color x:Key="Accent">#2196F3</Color>
    <Color x:Key="AccentVeryLight">#E3F2FD</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Category colors -->
    <Color x:Key="BreakfastColor">#FF9800</Color>
    <Color x:Key="LunchColor">#4CAF50</Color>
    <Color x:Key="DinnerColor">#E91E63</Color>
    <Color x:Key="DessertColor">#9C27B0</Color>
    <Color x:Key="SnackColor">#FF5722</Color>
    <Color x:Key="DrinkColor">#2196F3</Color>

    <!-- Light theme -->
    <Color x:Key="Light_White">#FFFFFF</Color>
    <Color x:Key="Light_Background">#FFF8F5</Color>
    <Color x:Key="Light_Surface">#FFFFFF</Color>
    <Color x:Key="Light_Card">#FFFFFF</Color>
    <Color x:Key="Light_TextPrimary">#212121</Color>
    <Color x:Key="Light_TextSecondary">#757575</Color>
    <Color x:Key="Light_Border">#E0E0E0</Color>

    <!-- Dark theme -->
    <Color x:Key="Dark_White">#FFFFFF</Color>
    <Color x:Key="Dark_Background">#0D1117</Color>
    <Color x:Key="Dark_Surface">#161B22</Color>
    <Color x:Key="Dark_Card">#1C2333</Color>
    <Color x:Key="Dark_TextPrimary">#E6EDF3</Color>
    <Color x:Key="Dark_TextSecondary">#8B949E</Color>
    <Color x:Key="Dark_Border">#30363D</Color>

    <!-- Aliases: pages reference these, styles handle dark mode -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="PageBackground">#FFF8F5</Color>
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="ShellBackground">#FFFFFF</Color>
    <Color x:Key="ShellForeground">#FF6B35</Color>
    <Color x:Key="ShellUnselected">#9E9E9E</Color>

</ResourceDictionary>
