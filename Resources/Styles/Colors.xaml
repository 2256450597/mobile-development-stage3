<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- === Japanese Minimalism / Old Money Palette === -->

    <!-- Core monochrome -->
    <Color x:Key="Black">#1A1A1A</Color>
    <Color x:Key="OffBlack">#2C2C2C</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="OffWhite">#FAFAF7</Color>
    <Color x:Key="WarmCreamOld">#F5F3EE</Color>

    <!-- Single accent: muted terracotta -->
    <Color x:Key="Accent">#A0603F</Color>
    <Color x:Key="AccentLight">#C4896A</Color>
    <Color x:Key="AccentVeryLight">#F5EBE4</Color>

    <!-- Subtle green accent -->
    <Color x:Key="Green">#4A6B53</Color>
    <Color x:Key="GreenLight">#6B8F76</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#767676</Color>
    <Color x:Key="TextTertiary">#A3A3A3</Color>

    <!-- Border & Divider -->
    <Color x:Key="BorderLight">#E8E5DF</Color>
    <Color x:Key="Divider">#EFECE5</Color>

    <!-- Semantic: keep minimal, use words not colors -->
    <Color x:Key="Danger">#B85450</Color>
    <Color x:Key="Success">#4A6B53</Color>

    <!-- Category tags: subtle tinted backgrounds -->
    <Color x:Key="TagBreakfast">#F5EBE4</Color>
    <Color x:Key="TagLunch">#E8EFE9</Color>
    <Color x:Key="TagDinner">#F0E8E8</Color>
    <Color x:Key="TagDessert">#EDE8F2</Color>
    <Color x:Key="TagSnack">#FAF0E4</Color>
    <Color x:Key="TagDrink">#E2EEF0</Color>

    <!-- Tag text colors -->
    <Color x:Key="TagTextBreakfast">#8B5E3C</Color>
    <Color x:Key="TagTextLunch">#4A6B53</Color>
    <Color x:Key="TagTextDinner">#8B4B4B</Color>
    <Color x:Key="TagTextDessert">#6B4B7B</Color>
    <Color x:Key="TagTextSnack">#8B6E4B</Color>
    <Color x:Key="TagTextDrink">#3B6B7B</Color>

    <!-- Dark mode -->
    <Color x:Key="Dark_Background">#141412</Color>
    <Color x:Key="Dark_Surface">#1E1E1B</Color>
    <Color x:Key="Dark_Card">#252522</Color>
    <Color x:Key="Dark_TextPrimary">#EBE8E0</Color>
    <Color x:Key="Dark_TextSecondary">#8A8880</Color>
    <Color x:Key="Dark_Border">#333330</Color>
    <Color x:Key="Dark_Divider">#2C2C28</Color>

    <!-- Legacy aliases for existing bindings -->
    <Color x:Key="Primary">#A0603F</Color>
    <Color x:Key="PrimaryDark">#8B4E32</Color>
    <Color x:Key="PrimaryLight">#C4896A</Color>
    <Color x:Key="PrimaryVeryLight">#F5EBE4</Color>
    <Color x:Key="Secondary">#4A6B53</Color>
    <Color x:Key="SecondaryDark">#3B5643</Color>
    <Color x:Key="SecondaryVeryLight">#E8EFE9</Color>
    <Color x:Key="Error">#B85450</Color>
    <Color x:Key="Warning">#D4A24E</Color>

    <Color x:Key="BreakfastColor">#8B5E3C</Color>
    <Color x:Key="LunchColor">#4A6B53</Color>
    <Color x:Key="DinnerColor">#8B4B4B</Color>
    <Color x:Key="DessertColor">#6B4B7B</Color>
    <Color x:Key="SnackColor">#8B6E4B</Color>
    <Color x:Key="DrinkColor">#3B6B7B</Color>

    <!-- Deprecated light theme aliases (for backward compat) -->
    <Color x:Key="Light_Background">#FEF7F0</Color>
    <Color x:Key="Light_Surface">#FFFFFF</Color>
    <Color x:Key="Light_Card">#FFFFFF</Color>
    <Color x:Key="Light_TextPrimary">#1A1A1A</Color>
    <Color x:Key="Light_TextSecondary">#767676</Color>
    <Color x:Key="Light_Border">#E8E5DF</Color>
    <Color x:Key="Dark_White">#FFFFFF</Color>
    <Color x:Key="Dark_TextPrimary_Alt">#EBE8E0</Color>
    <Color x:Key="Dark_TextSecondary_Alt">#8A8880</Color>
    <Color x:Key="Dark_Border_Alt">#333330</Color>

    <Color x:Key="PageBackground">#FEF7F0</Color>
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E8E5DF</Color>
    <Color x:Key="ShellBackground">#FFFFFF</Color>
    <Color x:Key="ShellForeground">#1A1A1A</Color>
    <Color x:Key="ShellUnselected">#A3A3A3</Color>

    <!-- === Bold Appetite Palette (Restaurant Red) === -->
    <Color x:Key="ChiliRed">#DC2626</Color>
    <Color x:Key="ChiliRedDark">#B91C1C</Color>
    <Color x:Key="ChiliRedLight">#FCA5A5</Color>
    <Color x:Key="ChiliRedBg">#FEF2F2</Color>
    <Color x:Key="WarmGold">#A16207</Color>
    <Color x:Key="WarmGoldLight">#FDE68A</Color>
    <Color x:Key="DeepRedText">#450A0A</Color>
    <Color x:Key="DeepRedMuted">#991B1B</Color>
    <Color x:Key="RedBorder">#FECACA</Color>
    <Color x:Key="RedBorderLight">#FEE2E2</Color>
    <Color x:Key="AppetiteCard">#FFFFFF</Color>
    <Color x:Key="AppetiteShadow">#1A000000</Color>
    <Color x:Key="AppetiteBadge">#FEF2F2</Color>

    <!-- Dark mode -->
    <Color x:Key="Dark_AppetiteBg">#0B0000</Color>
    <Color x:Key="Dark_AppetiteCard">#1A0909</Color>
    <Color x:Key="Dark_AppetiteBorder">#331111</Color>
    <Color x:Key="Dark_AppetiteText">#FEE2E2</Color>

</ResourceDictionary>
