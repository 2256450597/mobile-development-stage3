<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== Raw Color Palette ===== -->

    <!-- Primary - warm orange/food theme -->
    <Color x:Key="Primary">#FF6B35</Color>
    <Color x:Key="PrimaryDark">#E55A2B</Color>
    <Color x:Key="PrimaryLight">#FF8A5C</Color>
    <Color x:Key="PrimaryVeryLight">#FFF0E6</Color>

    <!-- Secondary - fresh green -->
    <Color x:Key="Secondary">#4CAF50</Color>
    <Color x:Key="SecondaryDark">#388E3C</Color>
    <Color x:Key="SecondaryLight">#81C784</Color>
    <Color x:Key="SecondaryVeryLight">#E8F5E9</Color>

    <!-- Accent -->
    <Color x:Key="Accent">#2196F3</Color>
    <Color x:Key="AccentDark">#1976D2</Color>
    <Color x:Key="AccentVeryLight">#E3F2FD</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Category colors -->
    <Color x:Key="BreakfastColor">#FF9800</Color>
    <Color x:Key="LunchColor">#4CAF50</Color>
    <Color x:Key="DinnerColor">#E91E63</Color>
    <Color x:Key="DessertColor">#9C27B0</Color>
    <Color x:Key="SnackColor">#FF5722</Color>
    <Color x:Key="DrinkColor">#2196F3</Color>

    <!-- ===== Light Theme Values ===== -->
    <Color x:Key="Light_White">#FFFFFF</Color>
    <Color x:Key="Light_Background">#FFF8F5</Color>
    <Color x:Key="Light_Surface">#FFFFFF</Color>
    <Color x:Key="Light_Card">#FFFFFF</Color>
    <Color x:Key="Light_TextPrimary">#212121</Color>
    <Color x:Key="Light_TextSecondary">#757575</Color>
    <Color x:Key="Light_Border">#E0E0E0</Color>
    <Color x:Key="Light_ShadowColor">#000000</Color>

    <!-- ===== Dark Theme Values ===== -->
    <Color x:Key="Dark_White">#FFFFFF</Color>
    <Color x:Key="Dark_Background">#0D1117</Color>
    <Color x:Key="Dark_Surface">#161B22</Color>
    <Color x:Key="Dark_Card">#1C2333</Color>
    <Color x:Key="Dark_TextPrimary">#E6EDF3</Color>
    <Color x:Key="Dark_TextSecondary">#8B949E</Color>
    <Color x:Key="Dark_Border">#30363D</Color>
    <Color x:Key="Dark_ShadowColor">#000000</Color>

    <!-- ===== Theme-Bound Colors (auto-switch via AppThemeBinding) ===== -->

    <Color x:Key="White"
           Color="{AppThemeBinding Light={StaticResource Light_White}, Dark={StaticResource Dark_White}}" />

    <Color x:Key="PageBackground"
           Color="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}" />

    <Color x:Key="SurfaceBackground"
           Color="{AppThemeBinding Light={StaticResource Light_Surface}, Dark={StaticResource Dark_Surface}}" />

    <Color x:Key="CardBackground"
           Color="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}" />

    <Color x:Key="TextPrimary"
           Color="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary}}" />

    <Color x:Key="TextSecondary"
           Color="{AppThemeBinding Light={StaticResource Light_TextSecondary}, Dark={StaticResource Dark_TextSecondary}}" />

    <Color x:Key="BorderColor"
           Color="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border}}" />

    <!-- Shell colors -->
    <Color x:Key="ShellBackground"
           Color="{AppThemeBinding Light={StaticResource Light_Surface}, Dark={StaticResource Dark_Surface}}" />

    <Color x:Key="ShellForeground" Color="{StaticResource Primary}" />

    <Color x:Key="ShellUnselected"
           Color="{AppThemeBinding Light=#9E9E9E, Dark=#6E7681}" />

</ResourceDictionary>
