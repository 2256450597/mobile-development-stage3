<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:converters="clr-namespace:TastyMealPlanner.Converters">

    <!-- Converters -->
    <converters:BoolToStrikethroughConverter x:Key="BoolToStrikethrough" />
    <converters:InverseBoolConverter x:Key="InverseBool" />
    <converters:CategoryToColorConverter x:Key="CategoryToColor" />
    <converters:DifficultyToColorConverter x:Key="DifficultyToColor" />

    <!-- Page Style -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}" />
    </Style>

    <!-- Shell Styling -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource ShellBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource ShellForeground}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource ShellUnselected}" />
    </Style>

    <!-- Label Styles -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondaryLight}" />
    </Style>

    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondaryLight}" />
    </Style>

    <Style x:Key="SectionTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="Margin" Value="16,20,0,8" />
    </Style>

    <!-- Card Frame Style -->
    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource CardLight}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderLight}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Margin" Value="8" />
    </Style>

    <!-- Primary Button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Secondary Button -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Icon Button -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="WidthRequest" Value="48" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="20" />
    </Style>

    <!-- Entry Style -->
    <Style x:Key="FormEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondaryLight}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- SearchBar Style -->
    <Style x:Key="SearchBarStyle" TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondaryLight}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- Badge/Chip Style for Categories -->
    <Style x:Key="CategoryChip" TargetType="Frame">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Margin" Value="4" />
    </Style>

</ResourceDictionary>
