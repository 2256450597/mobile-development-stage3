<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:converters="clr-namespace:TastyMealPlanner.Converters">

    <!-- Converters -->
    <converters:BoolToStrikethroughConverter x:Key="BoolToStrikethrough" />
    <converters:InverseBoolConverter x:Key="InverseBool" />
    <converters:CategoryToColorConverter x:Key="CategoryToColor" />
    <converters:DifficultyToColorConverter x:Key="DifficultyToColor" />
    <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />
	<converters:IsNotNullConverter x:Key="IsNotNull" />
	<converters:IsNullConverter x:Key="IsNull" />
	<converters:BoolToToggleOffsetConverter x:Key="BoolToToggleOffset" />

    <!-- ===== Frame (global default, no shadow) ===== -->
    <Style TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ===== Button (global default) ===== -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CharacterSpacing" Value="0.5" />
    </Style>

    <!-- ===== Entry ===== -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Dark_TextSecondary_Alt}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- ===== SearchBar ===== -->
    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Dark_TextSecondary_Alt}}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Primary}" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- ===== Picker ===== -->
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Dark_TextSecondary_Alt}}" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- ===== Switch ===== -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Accent}" />
    </Style>

    <!-- ===== Slider ===== -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource Accent}" />
        <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}" />
        <Setter Property="ThumbColor" Value="{StaticResource Accent}" />
    </Style>

    <!-- ===== ActivityIndicator ===== -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Accent}" />
    </Style>

    <!-- ===== Named Label Styles ===== -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontFamily" Value="PlayfairDisplayBold" />
        <Setter Property="CharacterSpacing" Value="-0.3" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="PlayfairDisplayBold" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="Margin" Value="16,28,0,10" />
    </Style>

    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <!-- Legacy named styles (keep for backward compat) -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontFamily" Value="PlayfairDisplayBold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontFamily" Value="PlayfairDisplay" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="SectionTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="PlayfairDisplayBold" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="Margin" Value="16,28,0,10" />
    </Style>

    <!-- Section headers with elegant serif -->
    <Style x:Key="VintageTitle" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontFamily" Value="PlayfairDisplayBold" />
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="Margin" Value="16,20,0,6" />
    </Style>

    <!-- ===== Card Frame (no shadow, thin border) ===== -->
    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Margin" Value="8" />
    </Style>

    <!-- ===== Primary Button ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- ===== Secondary Button ===== -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- ===== Icon Button (minimal circle) ===== -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentVeryLight}" />
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="WidthRequest" Value="48" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- ===== Form Entry ===== -->
    <Style x:Key="FormEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Dark_TextSecondary_Alt}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style x:Key="SearchBarStyle" TargetType="SearchBar">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource Dark_TextSecondary_Alt}}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Primary}" />
    </Style>

    <Style x:Key="CategoryChip" TargetType="Frame">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Margin" Value="4" />
    </Style>

</ResourceDictionary>
