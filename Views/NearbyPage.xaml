<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:services="clr-namespace:TastyMealPlanner.Services"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.NearbyPage"
             x:DataType="vm:NearbyViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="16">
        <views:HeaderLogo Grid.Row="0" />

        <!-- Location Status Card -->
        <Frame Grid.Row="2" Style="{StaticResource CardFrame}" Margin="0,0,0,8">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="8">
                    <Label Text=" " FontSize="20" VerticalTextAlignment="Center" />
                    <Label Text="Your Location"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Real address from Geocoding API -->
                <Label Text="{Binding Address}"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <!-- GPS coordinates -->
                <Label Text="{Binding Coordinates}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />

                <Label Text="{Binding LocationInfo}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />

                <!-- Compass heading (magnetometer) -->
                <HorizontalStackLayout Spacing="8" IsVisible="{Binding HasCompass}">
                    <Label Text="&#x2191;" FontSize="18"
                           TextColor="{StaticResource Primary}" VerticalTextAlignment="Center" />
                    <Label Text="{Binding HeadingDisplay}" FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" VerticalTextAlignment="Center" />
                    <Label Text="{Binding CompassLabel}" FontSize="14"
                           TextColor="{StaticResource Primary}" VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsLocating}"
                                   IsVisible="{Binding IsLocating}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Start"
                                   HeightRequest="20" />
            </VerticalStackLayout>
        </Frame>

        <!-- Location Details Card -->
        <Frame Grid.Row="1"
               Style="{StaticResource CardFrame}"
               IsVisible="{Binding HasLocation}"
               Margin="0,4">
            <VerticalStackLayout Spacing="8">
                <Label Text="Address"
                       FontAttributes="Bold" FontSize="14"
                       TextColor="{StaticResource Primary}" />
                <Label Text="{Binding Address}"
                       FontSize="14"
                       TextColor="{StaticResource TextPrimary}" />
                <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />
                <Label Text="Coordinates"
                       FontAttributes="Bold" FontSize="14"
                       TextColor="{StaticResource Primary}" />
                <Label Text="{Binding Coordinates}"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
        </Frame>

        <!-- Nearby Places List Header -->
        <Label Grid.Row="2"
               Text="Nearby Stores"
               Style="{StaticResource SectionTitleLabel}"
               Margin="0,8,0,4" />

        <!-- Nearby Places List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding NearbyPlaces}"
                        Margin="0,24,0,8">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center" Spacing="8"
                                     Padding="0,20">
                    <Label Text="No stores found"
                           FontSize="14" HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:NearbyPlace">
                    <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                            <!-- Store Icon -->
                            <Frame Grid.Column="0"
                                   BackgroundColor="{StaticResource PrimaryLight}"
                                   CornerRadius="4"
                                   WidthRequest="44" HeightRequest="44"
                                   Padding="0" HasShadow="False">
                                <Label Text="{Binding IconGlyph}"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>

                            <!-- Store Info -->
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Address}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <!-- Distance -->
                            <Frame Grid.Column="2"
                                   BackgroundColor="{StaticResource Primary}"
                                   CornerRadius="4" Padding="10,6"
                                   HasShadow="False"
                                   VerticalOptions="Center">
                                <Label FontSize="12" FontAttributes="Bold"
                                       TextColor="White">
                                    <Label.Text>
                                        <Binding Path="DistanceKm"
                                                 StringFormat="{}{0:F1} km" />
                                    </Label.Text>
                                </Label>
                            </Frame>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Refresh Button -->
        <Button Grid.Row="3"
                Text="Refresh Location"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding RefreshLocationCommand}"
                HeightRequest="50"
                FontSize="16"
                CornerRadius="4"
                Margin="16,8,16,24"
                IsEnabled="{Binding IsLocating, Converter={StaticResource InverseBool}}"
                SemanticProperties.Description="Refresh your current location" />

    </Grid>

</ContentPage>
