<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:services="clr-namespace:TastyMealPlanner.Services"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.NearbyPage"
             x:DataType="vm:NearbyViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Padding="16">
        <views:HeaderLogo Grid.Row="0" />

        <!-- User guidance -->
        <Label Grid.Row="1" Text="Discover grocery stores near your current location"
               FontSize="12" HorizontalTextAlignment="Center"
               TextColor="{StaticResource TextTertiary}" Margin="0,0,0,10" />

        <!-- Location Status + Compass Card -->
        <Frame Grid.Row="2" Style="{StaticResource CardFrame}" Margin="0,0,0,8">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="📍" FontSize="20" VerticalTextAlignment="Center" />
                    <Label Text="Your Location"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Status message -->
                <Label Text="{Binding LocationInfo}"
                       FontSize="13" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />

                <!-- Compass heading (magnetometer hardware) -->
                <HorizontalStackLayout Spacing="8" Padding="0,4" HorizontalOptions="Center">
                    <Label Text="🧭" FontSize="20" VerticalTextAlignment="Center" />
                    <Label Text="Compass:" FontSize="14"
                           TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center" />
                    <Label Text="{Binding HeadingDisplay}" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" VerticalTextAlignment="Center" />
                    <Label Text="{Binding CompassLabel}" FontSize="16"
                           TextColor="{StaticResource Primary}" VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsLocating}"
                                   IsVisible="{Binding IsLocating}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Start"
                                   HeightRequest="20" />
            </VerticalStackLayout>
        </Frame>

        <!-- Address + Coordinates Card -->
        <Frame Grid.Row="3" Style="{StaticResource CardFrame}"
               IsVisible="{Binding HasLocation}" Margin="0,4">
            <VerticalStackLayout Spacing="8">
                <Label Text="Address" FontAttributes="Bold" FontSize="14"
                       TextColor="{StaticResource Primary}" />
                <Label Text="{Binding Address}" FontSize="14"
                       TextColor="{StaticResource TextPrimary}" />
                <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />
                <Label Text="Coordinates" FontAttributes="Bold" FontSize="14"
                       TextColor="{StaticResource Primary}" />
                <Label Text="{Binding Coordinates}" FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
        </Frame>

        <!-- Nearby Places List Header -->
        <Label Grid.Row="4" Text="Nearby Stores"
               Style="{StaticResource SectionTitleLabel}"
               Margin="0,8,0,4" />

        <!-- Nearby Places List -->
        <CollectionView Grid.Row="4" ItemsSource="{Binding NearbyPlaces}"
                        Margin="0,4,0,8">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center" Spacing="8"
                                     Padding="0,20">
                    <Label Text="No stores found"
                           FontSize="14" HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:NearbyPlace">
                    <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                            <Frame Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                   CornerRadius="4" WidthRequest="44" HeightRequest="44"
                                   Padding="0" HasShadow="False">
                                <Label Text="{Binding IconGlyph}" FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Address}" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Frame Grid.Column="2" BackgroundColor="{StaticResource Primary}"
                                   CornerRadius="4" Padding="10,6" HasShadow="False"
                                   VerticalOptions="Center">
                                <Label FontSize="12" FontAttributes="Bold" TextColor="White"
                                       Text="{Binding DistanceKm, StringFormat='{0:F1} km'}" />
                            </Frame>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Refresh Button -->
        <Button Grid.Row="5" Text="Refresh Location"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding RefreshLocationCommand}"
                HeightRequest="50" FontSize="16" CornerRadius="4"
                Margin="16,8,16,24"
                IsEnabled="{Binding IsLocating, Converter={StaticResource InverseBool}}"
                SemanticProperties.Description="Refresh your current location" />
    </Grid>

</ContentPage>
