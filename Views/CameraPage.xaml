<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             x:Class="TastyMealPlanner.Views.CameraPage"
             x:DataType="vm:CameraViewModel"
             Title="Camera"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16,16,16,24">

        <!-- Status -->
        <Label Grid.Row="0" Text="{Binding StatusMessage}" FontSize="14"
               HorizontalTextAlignment="Center"
               TextColor="{StaticResource TextSecondary}" Margin="0,0,0,12" />

        <!-- Preview area -->
        <Frame Grid.Row="1" BackgroundColor="#1A1A2E" CornerRadius="4" Padding="0">
            <Grid>
                <!-- Empty state -->
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBool}}" Spacing="8">
                    <Label Text="Camera Preview" FontSize="18" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label Text="Tap a button below to get started" FontSize="13" TextColor="#AAAAAA" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <!-- Photo preview -->
                <Image Source="{Binding PhotoPath}" Aspect="AspectFill"
                       IsVisible="{Binding HasPhoto}" />
            </Grid>
        </Frame>

        <!-- Action buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,16,0,0">

            <Button Text="Take Photo" Style="{StaticResource PrimaryButton}"
                    Command="{Binding TakePhotoCommand}"
                    IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Description="Capture a photo with the camera" />

            <Button Text="Pick from Gallery" Style="{StaticResource SecondaryButton}"
                    Command="{Binding PickPhotoCommand}"
                    IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Description="Pick a photo from your gallery" />

            <Button Text="Take Another Photo" Style="{StaticResource PrimaryButton}"
                    Command="{Binding TakePhotoCommand}"
                    IsVisible="{Binding HasPhoto}"
                    SemanticProperties.Description="Capture another photo" />

            <Button Text="Clear Photo" Style="{StaticResource SecondaryButton}"
                    Command="{Binding ClearPhotoCommand}"
                    IsVisible="{Binding HasPhoto}"
                    SemanticProperties.Description="Clear the current photo" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
