<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.CameraPage"
             x:DataType="vm:CameraViewModel"
             Title="Camera"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16,16,16,24" RowSpacing="0">
        <views:HeaderLogo Grid.Row="0" />

        <!-- Status message -->
        <Label Grid.Row="1" Text="{Binding StatusMessage}" FontSize="13"
               HorizontalTextAlignment="Center"
               TextColor="{StaticResource TextSecondary}" Margin="0,0,0,8"
               LineBreakMode="TailTruncation" MaxLines="2" />

        <!-- === Preview Area (fills remaining space) === -->
        <Frame Grid.Row="2" BackgroundColor="#1A1A2E" CornerRadius="12"
               Padding="0" HasShadow="False" Margin="0,0,0,16" BorderColor="Transparent">
            <Grid>
                <!-- No photo yet -->
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBool}}"
                                     Spacing="16" Padding="24">
                    <Label Text="Camera Preview" FontSize="20"
                           TextColor="White" HorizontalTextAlignment="Center"
                           FontAttributes="Bold" />
                    <Label Text="Tap the large button below to capture your meal"
                           FontSize="14" TextColor="#999999"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Photo captured -->
                <Image Source="{Binding PhotoPath}" Aspect="AspectFill"
                       IsVisible="{Binding HasPhoto}" />

                <!-- ML classification chip -->
                <Border VerticalOptions="Start" HorizontalOptions="Center"
                        Margin="0,12,0,0" Padding="12,8"
                        StrokeShape="RoundRectangle 14" StrokeThickness="0"
                        BackgroundColor="#CC1A1A2E"
                        IsVisible="{Binding HasClassification}">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="ML" FontSize="11" TextColor="{StaticResource Primary}"
                               FontAttributes="Bold" VerticalTextAlignment="Center" />
                        <Label Text="{Binding ClassificationResult}" FontSize="12"
                               TextColor="White" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Frame>

        <!-- === Bottom Bar: BEFORE photo === -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,*"
              HeightRequest="88"
              IsVisible="{Binding HasPhoto, Converter={StaticResource InverseBool}}">
            <!-- Gallery button -->
            <Button Grid.Column="0" Text="Gallery"
                    Style="{StaticResource SecondaryButton}"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    Command="{Binding PickPhotoCommand}"
                    SemanticProperties.Description="Pick a photo from the device gallery" />
            <!-- Shutter button -->
            <Button Grid.Column="1" Text="Capture" FontAttributes="Bold"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" FontSize="16" FontFamily="OpenSansSemibold"
                    WidthRequest="80" HeightRequest="80" CornerRadius="40"
                    Padding="0" BorderWidth="0"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    Command="{Binding TakePhotoCommand}"
                    SemanticProperties.Description="Capture a photo with the camera" />
            <!-- Flash toggle -->
            <Button Grid.Column="2" Text="{Binding FlashlightLabel}"
                    Style="{StaticResource SecondaryButton}"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    Command="{Binding ToggleFlashlightCommand}"
                    IsVisible="{Binding HasFlashlight}"
                    SemanticProperties.Description="Toggle the device flashlight on or off" />
        </Grid>

        <!-- === Bottom Bar: AFTER photo === -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
              RowSpacing="10" ColumnSpacing="10"
              IsVisible="{Binding HasPhoto}">

            <!-- Use Photo (primary) -->
            <Button Grid.Row="0" Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Text="Use Photo"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding UsePhotoCommand}"
                    SemanticProperties.Description="Create a new recipe with this photo" />

            <!-- ML Classify (secondary) -->
            <Button Grid.Row="1" Grid.Column="0"
                    Text="Classify Food (ML)"
                    Style="{StaticResource SecondaryButton}" FontSize="13"
                    Command="{Binding ClassifyFoodCommand}"
                    IsVisible="{Binding IsModelReady}"
                    SemanticProperties.Description="Classify food using machine learning" />

            <!-- Retake (secondary) -->
            <Button Grid.Row="1" Grid.Column="0"
                    Text="Retake"
                    Style="{StaticResource SecondaryButton}" FontSize="13"
                    Command="{Binding TakePhotoCommand}"
                    IsVisible="{Binding IsModelReady, Converter={StaticResource InverseBool}}" />

            <!-- Discard (danger) -->
            <Button Grid.Row="1" Grid.Column="1"
                    Text="Discard"
                    Style="{StaticResource SecondaryButton}" FontSize="13"
                    Command="{Binding ClearPhotoCommand}"
                    TextColor="{StaticResource Error}" BorderColor="{StaticResource Error}"
                    SemanticProperties.Description="Discard the current photo" />
        </Grid>
    </Grid>

</ContentPage>
