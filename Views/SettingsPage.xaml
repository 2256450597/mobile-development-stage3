<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             x:Class="TastyMealPlanner.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- Appearance Section -->
            <Label Text="Appearance"
                   Style="{StaticResource SectionTitleLabel}"
                   SemanticProperties.HeadingLevel="Level2" />

            <Frame Style="{StaticResource CardFrame}" Margin="12,0">
                <VerticalStackLayout Spacing="12">

                    <!-- Dark Mode Toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Dark Mode"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   SemanticProperties.Description="Toggle dark mode" />
                            <Label Text="Switch between light and dark appearance"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsDarkMode}"
                                OnColor="{StaticResource Primary}"
                                SemanticProperties.Description="Dark mode switch" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

                    <!-- Font Size Picker -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Font Size"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               SemanticProperties.Description="Choose font size" />
                        <Label Text="Adjust the app text size for better readability"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <Picker ItemsSource="{Binding FontSizeOptions}"
                                SelectedItem="{Binding SelectedFontSize}"
                                Title="Select Font Size"
                                TextColor="{StaticResource TextPrimary}"
                                TitleColor="{StaticResource TextSecondary}"
                                SemanticProperties.Description="Font size picker" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Accessibility Section -->
            <Label Text="Accessibility"
                   Style="{StaticResource SectionTitleLabel}"
                   SemanticProperties.HeadingLevel="Level2" />

            <Frame Style="{StaticResource CardFrame}" Margin="12,0">
                <VerticalStackLayout Spacing="12">
                    <Label Text="This app follows WCAG 2.1 guidelines to ensure accessibility for all users."
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />

                    <Label FontSize="13" TextColor="{StaticResource TextPrimary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="&#x2022; " />
                                <Span Text="All images include descriptive alt text for screen readers." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label FontSize="13" TextColor="{StaticResource TextPrimary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="&#x2022; " />
                                <Span Text="Semantic heading levels are defined for navigation." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label FontSize="13" TextColor="{StaticResource TextPrimary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="&#x2022; " />
                                <Span Text="Touch targets meet minimum size requirements (44pt)." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label FontSize="13" TextColor="{StaticResource TextPrimary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="&#x2022; " />
                                <Span Text="High contrast colour ratios for text readability." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label FontSize="13" TextColor="{StaticResource TextPrimary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="&#x2022; " />
                                <Span Text="Text-to-speech support for recipe instructions." />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Frame>

            <!-- Hardware Settings Section -->
            <Label Text="Hardware Settings"
                   Style="{StaticResource SectionTitleLabel}"
                   SemanticProperties.HeadingLevel="Level2" />

            <Frame Style="{StaticResource CardFrame}" Margin="12,0">
                <VerticalStackLayout Spacing="14">

                    <!-- TTS Speed -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Text-to-Speech Speed"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Adjust how fast recipes are read aloud"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Slider Grid.Column="0"
                                    Minimum="0.5" Maximum="2.0"
                                    Value="{Binding TtsSpeed}"
                                    MinimumTrackColor="{StaticResource Primary}"
                                    MaximumTrackColor="{StaticResource BorderColor}"
                                    ThumbColor="{StaticResource Primary}" />
                            <Label Grid.Column="1"
                                   Text="{Binding TtsSpeed, StringFormat='{0:F1}x'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalTextAlignment="Center"
                                   WidthRequest="40" />
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

                    <!-- TTS Pitch -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Text-to-Speech Pitch"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Adjust the voice pitch for reading"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Slider Grid.Column="0"
                                    Minimum="0.5" Maximum="2.0"
                                    Value="{Binding TtsPitch}"
                                    MinimumTrackColor="{StaticResource Accent}"
                                    MaximumTrackColor="{StaticResource BorderColor}"
                                    ThumbColor="{StaticResource Accent}" />
                            <Label Grid.Column="1"
                                   Text="{Binding TtsPitch, StringFormat='{0:F1}x'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource Accent}"
                                   VerticalTextAlignment="Center"
                                   WidthRequest="40" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Test TTS Button -->
                    <Button Text="&#x1F50A; Test Text-to-Speech"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding TestTtsCommand}"
                            SemanticProperties.Description="Test text-to-speech with current settings"
                            Margin="0,4,0,0" />

                </VerticalStackLayout>
            </Frame>

            <!-- About Section -->
            <Label Text="About"
                   Style="{StaticResource SectionTitleLabel}"
                   SemanticProperties.HeadingLevel="Level2" />

            <Frame Style="{StaticResource CardFrame}" Margin="12,0,12,30">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Tasty Meal Planner"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="Version 1.0"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Text="A mobile meal planning application built with .NET MAUI for organising weekly meals, discovering recipes, and managing shopping lists."
                           FontSize="13"
                           TextColor="{StaticResource TextPrimary}" />

                    <Button Text="More Information"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AboutCommand}"
                            Margin="0,8,0,0"
                            SemanticProperties.Description="View more information about the app" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
