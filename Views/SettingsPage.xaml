<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Shell.NavBarIsVisible="False" Title="Settings"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">
        <views:HeaderLogo Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="16,8,16,32">

                <!-- Hero Card -->
                <Border StrokeShape="RoundRectangle 20" StrokeThickness="0"
                        Padding="20" Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#40000000" Offset="0,6" Radius="20" Opacity="0.3" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nosh Your Nosh" FontSize="12"
                               TextColor="#D0B8A8" CharacterSpacing="1" />
                        <Label Text="Preferences" FontSize="24" FontAttributes="Bold"
                               TextColor="White" />
                        <HorizontalStackLayout Spacing="12" Margin="0,6,0,0">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#33FFFFFF" Padding="8,4">
                                <Label Text="v1.0" FontSize="11" TextColor="White" />
                            </Border>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#33FFFFFF" Padding="8,4">
                                <Label Text="{Binding CurrentModeText}" FontSize="11" TextColor="White" />
                            </Border>
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#33FFFFFF" Padding="8,4">
                                <Label Text="{Binding CurrentFontLabel, StringFormat='Font: {0}'}"
                                       FontSize="11" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Row 1: Two side-by-side cards -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,20">

                    <!-- Dark Mode Card -->
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 14" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}"
                            Padding="16">
                        <Border.Shadow>
                            <Shadow Brush="#08000000" Offset="0,2" Radius="8" Opacity="0.2" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource PrimaryVeryLight}"
                                    WidthRequest="40" HeightRequest="40" Padding="0">
                                <Label Text="{Binding DarkModeIcon}" FontSize="20" FontFamily="MaterialIcons"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Dark Mode" FontSize="14" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                <Label Text="{Binding CurrentModeText}" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                    Padding="10,6" BackgroundColor="{StaticResource Primary}"
                                    HorizontalOptions="Start">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleDarkModeCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding DarkModeLabel}" FontSize="12"
                                       FontAttributes="Bold" TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Font Size Card -->
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 14" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}"
                            Padding="16">
                        <Border.Shadow>
                            <Shadow Brush="#08000000" Offset="0,2" Radius="8" Opacity="0.2" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource SecondaryVeryLight}"
                                    WidthRequest="40" HeightRequest="40" Padding="0">
                                <Label Text="&#xe262;" FontSize="20" FontFamily="MaterialIcons"
                                       TextColor="{StaticResource Secondary}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Font Size" FontSize="14" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                <Label Text="{Binding CurrentFontLabel}" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0" Padding="6,4"
                                        BackgroundColor="{Binding FontSmallBg}"
                                        HorizontalOptions="Fill">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectFontCommand}"
                                                              CommandParameter="Small" />
                                    </Border.GestureRecognizers>
                                    <Label Text="S" FontSize="11" FontAttributes="Bold"
                                           TextColor="{Binding FontSmallText}"
                                           HorizontalTextAlignment="Center" />
                                </Border>
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0" Padding="6,4"
                                        BackgroundColor="{Binding FontMediumBg}"
                                        HorizontalOptions="Fill">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectFontCommand}"
                                                              CommandParameter="Medium" />
                                    </Border.GestureRecognizers>
                                    <Label Text="M" FontSize="11" FontAttributes="Bold"
                                           TextColor="{Binding FontMediumText}"
                                           HorizontalTextAlignment="Center" />
                                </Border>
                                <Border Grid.Column="2" StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0" Padding="6,4"
                                        BackgroundColor="{Binding FontLargeBg}"
                                        HorizontalOptions="Fill">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectFontCommand}"
                                                              CommandParameter="Large" />
                                    </Border.GestureRecognizers>
                                    <Label Text="L" FontSize="11" FontAttributes="Bold"
                                           TextColor="{Binding FontLargeText}"
                                           HorizontalTextAlignment="Center" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Voice & Speech Card -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}"
                        Padding="16" Margin="0,0,0,20">
                    <Border.Shadow>
                        <Shadow Brush="#08000000" Offset="0,2" Radius="8" Opacity="0.2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource ChiliRedBg}"
                                    WidthRequest="40" HeightRequest="40" Padding="0">
                                <Label Text="&#xe050;" FontSize="20" FontFamily="MaterialIcons"
                                       TextColor="{StaticResource ChiliRed}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Text-to-Speech" FontSize="14" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                <Label Text="Voice pitch adjustment" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource SecondaryVeryLight}"
                                    Padding="8,4" VerticalOptions="Center">
                                <Label Text="{Binding TtsPitch, StringFormat='{0:F1}x'}"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource Secondary}" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="0.5" FontSize="11"
                                   TextColor="{StaticResource TextTertiary}" VerticalOptions="Center" />
                            <Slider Grid.Column="1" Minimum="0.5" Maximum="2.0"
                                    Value="{Binding TtsPitch}"
                                    MinimumTrackColor="{StaticResource Primary}"
                                    MaximumTrackColor="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                                    ThumbColor="{StaticResource Primary}" />
                            <Label Grid.Column="2" Text="2.0" FontSize="11"
                                   TextColor="{StaticResource TextTertiary}" VerticalOptions="Center" />
                        </Grid>

                        <Button Text="{Binding TtsButtonText}"
                                Command="{Binding TestTtsCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White" FontAttributes="Bold"
                                CornerRadius="10" HeightRequest="46" FontSize="14"
                                BorderWidth="0" />
                    </VerticalStackLayout>
                </Border>

                <!-- About -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}"
                        Padding="16" Margin="0,0,0,20">
                    <Border.Shadow>
                        <Shadow Brush="#08000000" Offset="0,2" Radius="8" Opacity="0.2" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{StaticResource PrimaryVeryLight}"
                                WidthRequest="40" HeightRequest="40" Padding="0">
                            <Label Text="&#xe88e;" FontSize="20" FontFamily="MaterialIcons"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Nosh Your Nosh" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                            <Label Text="Version 1.0 · Meal planning &amp; recipe discovery" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AboutCommand}" />
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
