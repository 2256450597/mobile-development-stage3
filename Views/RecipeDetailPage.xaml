<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             x:Class="TastyMealPlanner.Views.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Hero Image Placeholder -->
                <BoxView HeightRequest="220"
                         Color="{Binding Recipe.Category, Converter={StaticResource CategoryToColor}}" />

                <!-- Recipe Header Info -->
                <VerticalStackLayout Padding="20" Spacing="8"
                                     BackgroundColor="{StaticResource SurfaceLight}">
                    <Label Text="{Binding Recipe.Name}"
                           Style="{StaticResource TitleLabel}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label Text="{Binding Recipe.Description}"
                           Style="{StaticResource BodyLabel}" />

                    <!-- Stats Row -->
                    <HorizontalStackLayout Spacing="20" Margin="0,8,0,0">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Recipe.Calories}" FontSize="16"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="Calories" FontSize="11"
                                   TextColor="{StaticResource TextSecondaryLight}" />
                        </VerticalStackLayout>

                        <BoxView WidthRequest="1" Color="{StaticResource BorderLight}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Recipe.PrepTimeMinutes}" FontSize="16"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="Prep (min)" FontSize="11"
                                   TextColor="{StaticResource TextSecondaryLight}" />
                        </VerticalStackLayout>

                        <BoxView WidthRequest="1" Color="{StaticResource BorderLight}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Recipe.Servings}" FontSize="16"
                                   FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="Servings" FontSize="11"
                                   TextColor="{StaticResource TextSecondaryLight}" />
                        </VerticalStackLayout>

                        <BoxView WidthRequest="1" Color="{StaticResource BorderLight}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Recipe.Difficulty}" FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{Binding Recipe.Difficulty, Converter={StaticResource DifficultyToColor}}" />
                            <Label Text="Difficulty" FontSize="11"
                                   TextColor="{StaticResource TextSecondaryLight}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Ingredients Section -->
                <Label Text="Ingredients"
                       Style="{StaticResource SectionTitleLabel}"
                       SemanticProperties.HeadingLevel="Level2" />

                <VerticalStackLayout Padding="16,0" Spacing="6">
                    <BindableLayout.ItemsSource>
                        <Binding Path="Ingredients" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="&#x2022;" FontSize="16"
                                       TextColor="{StaticResource Primary}"
                                       VerticalTextAlignment="Center" />
                                <Label Text="{Binding .}" FontSize="14"
                                       TextColor="{StaticResource TextPrimaryLight}"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Instructions Section -->
                <Label Text="Instructions"
                       Style="{StaticResource SectionTitleLabel}"
                       SemanticProperties.HeadingLevel="Level2" />

                <VerticalStackLayout Padding="16,0,16,100" Spacing="12">
                    <BindableLayout.ItemsSource>
                        <Binding Path="Instructions" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Frame Style="{StaticResource CardFrame}" Margin="0"
                                   Padding="14" BackgroundColor="#FFF8F5">
                                <Label Text="{Binding .}" FontSize="14"
                                       TextColor="{StaticResource TextPrimaryLight}"
                                       LineBreakMode="WordWrap" />
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              Padding="16,12,16,24"
              BackgroundColor="{StaticResource SurfaceLight}">
            <Grid.Shadow>
                <Shadow Color="Black" Offset="0,-2" Radius="8" Opacity="0.1" />
            </Grid.Shadow>

            <Button Grid.Column="0"
                    Text="&#x1F4C5; Add to Meal Plan"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddToMealPlanCommand}"
                    SemanticProperties.Description="Add this recipe to your meal plan" />

            <Button Grid.Column="1"
                    Text="&#x1F50A; Read Aloud"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding SpeakRecipeCommand}"
                    SemanticProperties.Description="Read the recipe aloud using text-to-speech" />
        </Grid>

    </Grid>

    <!-- Toolbar Favorite Button -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="&#x2764;"
                     Command="{Binding ToggleFavoriteCommand}"
                     SemanticProperties.Description="Toggle favorite" />
    </ContentPage.ToolbarItems>

</ContentPage>
