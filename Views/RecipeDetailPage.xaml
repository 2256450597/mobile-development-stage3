<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <views:HeaderLogo Grid.Row="0" />
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding StopSpeakingCommand}"
                                   NumberOfTapsRequired="1" />
        </Grid.GestureRecognizers>

        <Label Grid.Row="1" Text="Tap the speaker to hear this recipe read aloud"
               FontSize="11" HorizontalTextAlignment="Center"
               TextColor="{StaticResource TextTertiary}" Margin="0,-4,0,6" />

        <!-- === Content Scroll === -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="0">

                <!-- === Hero Image with Floating Recipe Name === -->
                <Grid HeightRequest="240">
                    <Image Source="{Binding Recipe.ImageUrl}"
                           Aspect="AspectFill" HeightRequest="240" />
                    <BoxView HeightRequest="120" VerticalOptions="End">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#CC000000" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <Label Text="{Binding Recipe.Name}" FontSize="28"
                           FontAttributes="Bold" TextColor="White"
                           VerticalOptions="End" Margin="20,0,20,20"
                           LineBreakMode="WordWrap"
                           SemanticProperties.HeadingLevel="Level1" />
                </Grid>

                <!-- === Floating Info Bar (overlaps hero + content) === -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                        Padding="0" Margin="16,-20,16,0"
                        BackgroundColor="{AppThemeBinding Light=#FFF, Dark=#1E1C18}">
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,4" Radius="14" Opacity="0.35" />
                    </Border.Shadow>
                    <HorizontalStackLayout Padding="14,12" Spacing="14"
                                           HorizontalOptions="Center">
                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 6"
                                BackgroundColor="{Binding Recipe.Category, Converter={StaticResource CategoryToColor}}"
                                Padding="10,4">
                            <Label Text="{Binding Recipe.Category}" FontSize="14"
                                   TextColor="White" FontAttributes="Bold" />
                        </Border>
                        <Label Text="·" FontSize="20"
                               TextColor="{StaticResource TextTertiary}"
                               VerticalTextAlignment="Center" />
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding Recipe.PrepTimeMinutes, StringFormat='{0} min'}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <Label Text="·" FontSize="20"
                               TextColor="{StaticResource TextTertiary}"
                               VerticalTextAlignment="Center" />
                        <Label Text="{Binding Recipe.Calories, StringFormat='{0} cal'}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- === Ingredients Card === -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                        Padding="0" Margin="16,16,16,0"
                        BackgroundColor="{AppThemeBinding Light=#FFF, Dark=#1E1C18}">
                    <Border.Shadow>
                        <Shadow Brush="#18000000" Offset="0,2" Radius="10" Opacity="0.25" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="4,*" ColumnSpacing="0">
                        <BoxView WidthRequest="4"
                                 Color="{StaticResource Primary}"
                                 VerticalOptions="Fill"
                                 Margin="0,14,0,14" />
                        <VerticalStackLayout Grid.Column="1" Padding="16,14,16,14" Spacing="8">
                            <Label Text="Ingredients" FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   SemanticProperties.HeadingLevel="Level2" />
                            <BoxView HeightRequest="1"
                                     Color="{StaticResource Light_Border}"
                                     Margin="0,2" />
                            <VerticalStackLayout Spacing="6">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="Ingredients" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="·" FontSize="18"
                                                   TextColor="{StaticResource Primary}"
                                                   VerticalTextAlignment="Center" />
                                            <Label Text="{Binding .}" FontSize="14"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- === Instructions Card === -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                        Padding="0" Margin="16,12,16,16"
                        BackgroundColor="{AppThemeBinding Light=#FFF, Dark=#1E1C18}">
                    <Border.Shadow>
                        <Shadow Brush="#18000000" Offset="0,2" Radius="10" Opacity="0.25" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="4,*" ColumnSpacing="0">
                        <BoxView WidthRequest="4"
                                 Color="{StaticResource Primary}"
                                 VerticalOptions="Fill"
                                 Margin="0,14,0,14" />
                        <VerticalStackLayout Grid.Column="1" Padding="16,14,16,14" Spacing="10">
                            <Label Text="Instructions" FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   SemanticProperties.HeadingLevel="Level2" />
                            <BoxView HeightRequest="1"
                                     Color="{StaticResource Light_Border}"
                                     Margin="0,2" />
                            <VerticalStackLayout Spacing="10">
                                <BindableLayout.ItemsSource>
                                    <Binding Path="Instructions" />
                                </BindableLayout.ItemsSource>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Label Text="{Binding .}" FontSize="14"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="WordWrap" Padding="4,0" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- === Bottom Action Bar === -->
        <VerticalStackLayout Grid.Row="3" Spacing="10"
                             Padding="16,12,16,20"
                             BackgroundColor="{AppThemeBinding Light=#FFF, Dark=#1E1C18}">
            <BoxView HeightRequest="1" Color="{StaticResource Light_Border}" />

            <!-- Primary: Add to Meal Plan -->
            <Button Text="Add to Meal Plan" FontAttributes="Bold"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" FontSize="15"
                    CornerRadius="10" HeightRequest="50"
                    Padding="20,12" BorderWidth="0"
                    Command="{Binding AddToMealPlanCommand}"
                    SemanticProperties.Description="Add this recipe to your meal plan" />

            <!-- Secondary row: Speak + Fav -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Play button (visible when not speaking) -->
                <Button Grid.Column="0"
                        Text="Read Aloud"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding SpeakRecipeCommand}"
                        IsVisible="{Binding IsSpeaking, Converter={StaticResource InverseBool}}"
                        SemanticProperties.Description="Read the recipe aloud" />
                <!-- Stop button (visible when speaking) -->
                <Button Grid.Column="0"
                        Text="Stop"
                        BackgroundColor="{StaticResource Error}"
                        TextColor="White" FontAttributes="Bold"
                        CornerRadius="10" Padding="14,10" FontSize="14" BorderWidth="0"
                        Command="{Binding StopSpeakingCommand}"
                        IsVisible="{Binding IsSpeaking}"
                        SemanticProperties.Description="Stop reading" />
                <!-- Favorite toggle -->
                <Button Grid.Column="1"
                        Text="{Binding FavoriteLabel}"
                        Command="{Binding ToggleFavoriteCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryVeryLight}, Dark=#331111}"
                        TextColor="{StaticResource Primary}" FontAttributes="Bold"
                        CornerRadius="10" Padding="14,10" FontSize="14" BorderWidth="0"
                        SemanticProperties.Description="Toggle favorite" />
            </Grid>
        </VerticalStackLayout>

    </Grid>

</ContentPage>
