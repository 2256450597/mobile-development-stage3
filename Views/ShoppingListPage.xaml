<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.ShoppingListPage"
             x:DataType="vm:ShoppingListViewModel"
             Shell.NavBarIsVisible="False" Title="Shopping"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="0" RowSpacing="0">
        <!-- Row 0: Header -->
        <views:HeaderLogo Grid.Row="0" />

        <!-- Row 1: Compact Add Bar -->
        <Border Grid.Row="1" Margin="12,12,12,0" Padding="10,8"
                StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Light_Card}, Dark={StaticResource Dark_Card}}">
            <Border.Shadow>
                <Shadow Brush="#10000000" Offset="0,2" Radius="6" Opacity="0.2" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,64,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="Item name"
                       Text="{Binding NewItemName}"
                       PlaceholderColor="{StaticResource TextTertiary}"
                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                       BackgroundColor="Transparent" FontSize="14"
                       ReturnType="Next"
                       SemanticProperties.Description="Enter shopping item name" />
                <Entry Grid.Column="1" Placeholder="Qty"
                       Text="{Binding NewItemQuantity}"
                       PlaceholderColor="{StaticResource TextTertiary}"
                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                       BackgroundColor="Transparent" FontSize="14"
                       Keyboard="Text"
                       SemanticProperties.Description="Enter quantity" />
                <Button Grid.Column="2" Text="Add"
                        Command="{Binding AddItemCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold"
                        CornerRadius="10" Padding="14,0" FontSize="13" HeightRequest="40"
                        BorderWidth="0"
                        SemanticProperties.Description="Add item to shopping list" />
            </Grid>
        </Border>

        <!-- Row 2: Progress + validation -->
        <VerticalStackLayout Grid.Row="2" Padding="12,10,12,4" Spacing="6">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Shopping List" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1" Text="{Binding ProgressText}" FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalTextAlignment="Center" />
            </Grid>
            <ProgressBar Progress="{Binding ProgressFraction}"
                         ProgressColor="{StaticResource Primary}"
                         HeightRequest="4" />
            <Label Text="{Binding ValidationError}"
                   TextColor="{StaticResource Error}" FontSize="12"
                   Margin="0,2,0,0"
                   IsVisible="{Binding ValidationError, Converter={StaticResource StringNotEmpty}}" />
        </VerticalStackLayout>

        <!-- Row 3: Content -->
        <ScrollView Grid.Row="3" Padding="12,8,12,16"
                    VerticalOptions="Fill">
            <VerticalStackLayout Spacing="0">

                    <!-- Empty state -->
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="12" Padding="24,80,24,40"
                                         IsVisible="{Binding IsListEmpty}">
                        <Label Text="🛒" FontSize="40"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Shopping List is Empty" FontSize="17"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary},
                                                          Dark={StaticResource Dark_TextPrimary_Alt}}" />
                        <VerticalStackLayout Spacing="10" Margin="0,8,0,0">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="🥘" FontSize="18"
                                       VerticalTextAlignment="Start" Margin="0,2,0,0" />
                                <Label FontSize="13" LineBreakMode="WordWrap"
                                       MaximumWidthRequest="260"
                                       VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Auto-add: " FontAttributes="Bold"
                                                  TextColor="{StaticResource Primary}" />
                                            <Span Text="Choose recipes in Today's Meal — their ingredients show up here automatically."
                                                  TextColor="{StaticResource TextSecondary}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="✏️" FontSize="18"
                                       VerticalTextAlignment="Start" Margin="0,2,0,0" />
                                <Label FontSize="13" LineBreakMode="WordWrap"
                                       MaximumWidthRequest="260"
                                       VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Manual: " FontAttributes="Bold"
                                                  TextColor="{StaticResource Primary}" />
                                            <Span Text="Type an item name and quantity above, then tap Add."
                                                  TextColor="{StaticResource TextSecondary}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Items list -->
                    <VerticalStackLayout Spacing="6" Margin="0,0,0,24"
                                IsVisible="{Binding IsListEmpty, Converter={StaticResource InverseBool}}"
                                BindableLayout.ItemsSource="{Binding Items}">
                        <BindableLayout.EmptyView>
                            <Label Text="No items yet."
                                   FontSize="13" TextColor="{StaticResource TextTertiary}"
                                   HorizontalTextAlignment="Center" Margin="0,8" />
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:ShoppingItem">
                                <Border StrokeShape="RoundRectangle 20"
                                        Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                                        StrokeThickness="1" Padding="10,6">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsChecked}" Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{StaticResource SecondaryVeryLight}" />
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource SecondaryVeryLight}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.BackgroundColor>
                                        <AppThemeBinding Light="{StaticResource Light_Card}" Dark="{StaticResource Dark_Card}" />
                                    </Border.BackgroundColor>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Border Grid.Column="0" StrokeShape="RoundRectangle 4"
                                                StrokeThickness="0" WidthRequest="20" HeightRequest="20"
                                                VerticalOptions="Center" Padding="0">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsChecked}" Value="False">
                                                    <Setter Property="Stroke" Value="{StaticResource TextTertiary}" />
                                                    <Setter Property="StrokeThickness" Value="2" />
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsChecked}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShoppingListViewModel}}, Path=ToggleItemCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                            <Label Text="{Binding Name}" FontSize="14" VerticalTextAlignment="Center"
                                                   TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsChecked}" Value="True">
                                                        <Setter Property="TextColor" Value="{StaticResource TextTertiary}" />
                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Label Text="{Binding Quantity}" FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   IsVisible="{Binding Quantity, Converter={StaticResource StringNotEmpty}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShoppingListViewModel}}, Path=ToggleItemCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
        </ScrollView>

        <!-- Clear Purchased Button -->
        <Button Grid.Row="4" Text="{Binding ClearButtonText}"
                Command="{Binding ClearCheckedCommand}"
                IsVisible="{Binding ShowClearButton}"
                Margin="12,8,12,20"
                BackgroundColor="Transparent"
                TextColor="{StaticResource Error}"
                FontSize="14" FontAttributes="Bold"
                BorderWidth="2"
                BorderColor="{StaticResource Error}"
                CornerRadius="10"
                HeightRequest="50"
                SemanticProperties.Description="Remove all purchased items from the list" />

    </Grid>

</ContentPage>
