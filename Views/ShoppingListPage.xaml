<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             x:Class="TastyMealPlanner.Views.ShoppingListPage"
             x:DataType="vm:ShoppingListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- Add Item Section -->
        <Frame Grid.Row="0" Margin="12,12,12,8"
               Style="{StaticResource CardFrame}">
            <VerticalStackLayout Spacing="6">
                <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Item name"
                           Text="{Binding NewItemName}"
                           Style="{StaticResource FormEntry}"
                           SemanticProperties.Description="Enter shopping item name"
                           ReturnType="Next" />

                    <Entry Grid.Column="1"
                           Placeholder="Qty"
                           Text="{Binding NewItemQuantity}"
                           Style="{StaticResource FormEntry}"
                           SemanticProperties.Description="Enter quantity"
                           ReturnType="Done" />

                    <Button Grid.Column="2"
                            Text="+"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddItemCommand}"
                            SemanticProperties.Description="Add item to shopping list"
                            HeightRequest="44" WidthRequest="44"
                            Padding="0" />
                </Grid>

                <!-- Validation Error -->
                <Label Text="{Binding ValidationError}"
                       TextColor="{StaticResource Error}"
                       FontSize="12"
                       IsVisible="{Binding ValidationError, Converter={StaticResource StringNotEmpty}}"
                       Margin="4,0,0,0" />
            </VerticalStackLayout>
        </Frame>

        <!-- Shopping List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        Margin="12,4">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center" Spacing="8">
                    <Label Text="&#x1F6D2;" FontSize="40"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Your shopping list is empty"
                           FontSize="16" HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ShoppingItem">
                    <Frame Style="{StaticResource CardFrame}" Margin="0,3">
                        <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="10">
                            <!-- Checkbox -->
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsChecked}"
                                      Color="{StaticResource Primary}"
                                      SemanticProperties.Description="Mark item as purchased"
                                      VerticalOptions="Center" />

                            <!-- Item Name -->
                            <Label Grid.Column="1"
                                   VerticalTextAlignment="Center"
                                   FontSize="15"
                                   TextColor="{StaticResource TextPrimary}"
                                   TextDecorations="{Binding IsChecked, Converter={StaticResource BoolToStrikethrough}}">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} - {1}">
                                        <Binding Path="Name" />
                                        <Binding Path="Quantity" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>

                            <!-- Tap to toggle -->
                            <Label Grid.Column="2"
                                   Text="&#x2716;" FontSize="14"
                                   TextColor="{StaticResource Error}"
                                   VerticalTextAlignment="Center"
                                   SemanticProperties.Description="Delete item">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShoppingListViewModel}}, Path=ToggleItemCommand}"
                                        CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Clear Checked Button -->
        <Button Grid.Row="2"
                Text="Clear Purchased Items"
                Style="{StaticResource SecondaryButton}"
                Command="{Binding ClearCheckedCommand}"
                Margin="16,8,16,16"
                SemanticProperties.Description="Remove all purchased items from the list" />

    </Grid>

</ContentPage>
