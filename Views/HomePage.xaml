<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             x:Class="TastyMealPlanner.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- ===== TOP BAR: Tasty Logo + Quick Menu ===== -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">
            <Grid ColumnDefinitions="*,Auto" Padding="16,14,12,12"
                  BackgroundColor="{AppThemeBinding Light=#FEF7F0, Dark={StaticResource Dark_Background}}">
                <VerticalStackLayout Grid.Column="0" Spacing="0">
                    <Label Text="Tasty" FontSize="34"
                           FontFamily="Pacifico"
                           TextColor="{AppThemeBinding Light=#D94E34, Dark=#E8784A}"
                           SemanticProperties.Description="Tasty home">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Discover what to cook today" FontSize="11"
                           TextColor="{StaticResource TextTertiary}" Margin="2,0,0,0" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="+" Style="{StaticResource IconButton}"
                        Command="{Binding ShowQuickMenuCommand}"
                        FontSize="22" TextColor="{StaticResource TextPrimary}"
                        BackgroundColor="Transparent"
                        SemanticProperties.Description="Open quick actions menu" />
            </Grid>
            <!-- Divider shadow -->
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E8E3DC, Dark=#2C2C28}" />
        </VerticalStackLayout>

        <!-- ===== MAIN: ScrollView ===== -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,24">

                <!-- Today's Meals (only if planned) -->
                <VerticalStackLayout Margin="0,8,0,12">
                    <Grid ColumnDefinitions="*,Auto" Padding="16,6,16,8">
                        <Label Text="Today's Meals" FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding TodayMeals}" HeightRequest="150">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.Header>
                            <BoxView WidthRequest="16" Color="Transparent" />
                        </CollectionView.Header>
                        <CollectionView.Footer>
                            <BoxView WidthRequest="16" Color="Transparent" />
                        </CollectionView.Footer>
                        <CollectionView.EmptyView>
                            <Label Text="No meals planned for today" Margin="16,12"
                                   TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MealPlanEntry">
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                                        StrokeThickness="1" Padding="0" WidthRequest="140"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                    <Border.Shadow>
                                        <Shadow Brush="#10000000" Offset="0,1" Radius="4" Opacity="0.3" />
                                    </Border.Shadow>
                                    <VerticalStackLayout>
                                        <Image Source="{Binding Recipe.ImageUrl}"
                                               HeightRequest="90" Aspect="AspectFill" />
                                        <VerticalStackLayout Padding="8,6" Spacing="2">
                                            <Label Text="{Binding MealType}" FontSize="10"
                                                   TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                                            <Label Text="{Binding Recipe.Name}" FontSize="12" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                                                   LineBreakMode="TailTruncation" MaxLines="1" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToRecipeDetailCommand}"
                                            CommandParameter="{Binding Recipe}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Curated Collections -->
                <CollectionView ItemsSource="{Binding Collections}" Margin="0,4,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:CuratedCollection">
                            <VerticalStackLayout Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,Auto" Padding="16,6,16,8">
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                    <Label Grid.Column="1" Text="{Binding Subtitle}" FontSize="12"
                                           TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding Recipes}" HeightRequest="140">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.Header>
                                        <BoxView WidthRequest="16" Color="Transparent" />
                                    </CollectionView.Header>
                                    <CollectionView.Footer>
                                        <BoxView WidthRequest="16" Color="Transparent" />
                                    </CollectionView.Footer>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Recipe">
                                            <Border StrokeShape="RoundRectangle 8"
                                                    Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                                                    StrokeThickness="1" Padding="0" WidthRequest="120"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                                <VerticalStackLayout>
                                                    <Image Source="{Binding ImageUrl}"
                                                           HeightRequest="85" Aspect="AspectFill" />
                                                    <Label Text="{Binding Name}" FontSize="11" FontAttributes="Bold"
                                                           Padding="8,6" LineBreakMode="TailTruncation" MaxLines="2"
                                                           TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                                </VerticalStackLayout>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToRecipeDetailCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- All Recipes - single column large image feed -->
                <Label Text="All Recipes" FontSize="16" FontAttributes="Bold"
                       Padding="16,12,16,8"
                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                <CollectionView ItemsSource="{Binding RecipeGrid}" Margin="0,0,0,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Recipe">
                            <Border StrokeShape="RoundRectangle 4"
                                    Stroke="Transparent" StrokeThickness="0"
                                    Padding="0" Margin="0,0,0,1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                <VerticalStackLayout>
                                    <!-- Large full-width food image -->
                                    <Image Source="{Binding ImageUrl}"
                                           HeightRequest="220" Aspect="AspectFill" />
                                    <VerticalStackLayout Padding="16,12" Spacing="4">
                                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" MaxLines="2"
                                               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                        <HorizontalStackLayout Spacing="12">
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}">
                                                <Label.Text>
                                                    <MultiBinding StringFormat="{}{0} min">
                                                        <Binding Path="PrepTimeMinutes" />
                                                    </MultiBinding>
                                                </Label.Text>
                                            </Label>
                                            <Label Text="·" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}"
                                                   Text="{Binding Calories, StringFormat='{0} cal'}" />
                                            <Label Text="·" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}"
                                                   Text="{Binding Difficulty}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToRecipeDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
