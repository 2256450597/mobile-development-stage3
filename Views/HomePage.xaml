<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             x:Class="TastyMealPlanner.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- ===== TOP BAR: Logo + Quick Menu ===== -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">
            <Grid ColumnDefinitions="*,Auto" Padding="16,14,12,12"
                  BackgroundColor="{AppThemeBinding Light=#FEF7F0, Dark=#1E1C18}">
                <VerticalStackLayout Grid.Column="0" Spacing="0">
                    <Label Text="Tasty Meal Planner" FontSize="30" FontFamily="Pacifico"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EBE8E0}"
                           SemanticProperties.Description="Tasty Meal Planner">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Discover what to cook today" FontSize="11"
                           TextColor="{StaticResource TextTertiary}" Margin="2,0,0,0" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="+" Style="{StaticResource IconButton}"
                        Command="{Binding ShowQuickMenuCommand}" FontSize="22"
                        TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent"
                        SemanticProperties.Description="Open quick actions menu" />
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E8E3DC, Dark=#2C2C28}" />
        </VerticalStackLayout>

        <!-- ===== MAIN: ScrollView ===== -->
        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,24">

                <!-- Today's Meals - Notepad Style -->
                <Border Margin="12,12,12,16" Padding="0"
                        StrokeShape="RoundRectangle 6"
                        Stroke="{AppThemeBinding Light=#E0D8CC, Dark=#3A3530}"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="#18000000" Offset="0,2" Radius="8" Opacity="0.35" />
                    </Border.Shadow>
                    <Grid>
                        <!-- Notepad texture background -->
                        <Image Source="notepad_bg.jpg" Aspect="AspectFill" Opacity="0.25" />
                        <VerticalStackLayout>
                        <!-- Clipboard clip decoration -->
                        <BoxView HeightRequest="4" Color="{StaticResource Accent}"
                                 HorizontalOptions="Center" WidthRequest="48"
                                 Margin="0,10,0,0" />
                        <!-- Title -->
                        <Label Text="Today's Meals" Style="{StaticResource VintageTitle}"
                               Padding="16,10,16,4"
                               TextColor="{AppThemeBinding Light=#5C4A3A, Dark=#C8B8A0}" />
                        <!-- Subtle ruled line -->
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E8E0D0, Dark=#2C2820}"
                                 Margin="16,0,16,0" />
                        <CollectionView ItemsSource="{Binding TodayMeals}" HeightRequest="160"
                                        Margin="0,8,0,12">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.Header>
                                <BoxView WidthRequest="16" Color="Transparent" />
                            </CollectionView.Header>
                            <CollectionView.Footer>
                                <BoxView WidthRequest="16" Color="Transparent" />
                            </CollectionView.Footer>
                            <CollectionView.EmptyView>
                                <Label Text="No meals planned for today" Margin="16,12"
                                       TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:MealPlanEntry">
                                    <Border StrokeShape="RoundRectangle 6"
                                            Stroke="{AppThemeBinding Light=#E8E0D0, Dark=#3A3530}"
                                            StrokeThickness="1" Padding="0" WidthRequest="140"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                        <Border.Shadow>
                                            <Shadow Brush="#10000000" Offset="0,1" Radius="4" Opacity="0.3" />
                                        </Border.Shadow>
                                        <VerticalStackLayout>
                                            <Image Source="{Binding Recipe.ImageUrl}"
                                                   HeightRequest="90" Aspect="AspectFill" />
                                            <VerticalStackLayout Padding="8,6" Spacing="2">
                                                <Label Text="{Binding MealType}" FontSize="10"
                                                       TextColor="{StaticResource Accent}" FontAttributes="Bold" />
                                                <Label Text="{Binding Recipe.Name}" FontSize="12" FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToRecipeDetailCommand}"
                                                CommandParameter="{Binding Recipe}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Curated Collections -->
                <CollectionView ItemsSource="{Binding Collections}" Margin="0,4,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:CuratedCollection">
                            <VerticalStackLayout Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,Auto" Padding="16,6,16,8">
                                    <HorizontalStackLayout Spacing="8">
                                        <BoxView WidthRequest="3" Color="{StaticResource Accent}"
                                                 HeightRequest="20" VerticalOptions="Center" />
                                        <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding Subtitle}" FontSize="12"
                                           TextColor="{StaticResource TextSecondary}" VerticalTextAlignment="Center" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding Recipes}" HeightRequest="145">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.Header>
                                        <BoxView WidthRequest="16" Color="Transparent" />
                                    </CollectionView.Header>
                                    <CollectionView.Footer>
                                        <BoxView WidthRequest="16" Color="Transparent" />
                                    </CollectionView.Footer>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Recipe">
                                            <Border StrokeShape="RoundRectangle 8"
                                                    Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                                                    StrokeThickness="1" Padding="0" WidthRequest="120"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                                <VerticalStackLayout>
                                                    <Grid>
                                                        <Image Source="{Binding ImageUrl}"
                                                               HeightRequest="85" Aspect="AspectFill" />
                                                        <!-- Category color badge -->
                                                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 3"
                                                                BackgroundColor="{Binding Category, Converter={StaticResource CategoryToColor}}"
                                                                Padding="6,2" HorizontalOptions="End" VerticalOptions="Start"
                                                                Margin="0,6,6,0">
                                                            <Label Text="{Binding Category}" FontSize="9"
                                                                   TextColor="White" FontAttributes="Bold" />
                                                        </Border>
                                                    </Grid>
                                                    <Label Text="{Binding Name}" FontSize="11" FontAttributes="Bold"
                                                           Padding="8,6" LineBreakMode="TailTruncation" MaxLines="2"
                                                           TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                                </VerticalStackLayout>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToRecipeDetailCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- All Recipes - single column large image feed -->
                <HorizontalStackLayout Spacing="8" Padding="16,16,16,8">
                    <BoxView WidthRequest="3" Color="{StaticResource Accent}"
                             HeightRequest="20" VerticalOptions="Center" />
                    <Label Text="All Recipes" Style="{StaticResource VintageTitle}" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                </HorizontalStackLayout>
                <CollectionView ItemsSource="{Binding RecipeGrid}" Margin="0,0,0,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Recipe">
                            <Border StrokeShape="RoundRectangle 4"
                                    Stroke="Transparent" StrokeThickness="0"
                                    Padding="0" Margin="0,0,0,1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                <VerticalStackLayout>
                                    <!-- Large full-width food image -->
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}"
                                               HeightRequest="220" Aspect="AspectFill" />
                                        <Border StrokeThickness="0" StrokeShape="RoundRectangle 3"
                                                BackgroundColor="{Binding Category, Converter={StaticResource CategoryToColor}}"
                                                Padding="8,3" HorizontalOptions="End" VerticalOptions="End"
                                                Margin="0,0,12,12">
                                            <Label Text="{Binding Category}" FontSize="10"
                                                   TextColor="White" FontAttributes="Bold" />
                                        </Border>
                                    </Grid>
                                    <VerticalStackLayout Padding="16,12" Spacing="4">
                                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" MaxLines="2"
                                               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />
                                        <HorizontalStackLayout Spacing="12">
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}">
                                                <Label.Text>
                                                    <MultiBinding StringFormat="{}{0} min">
                                                        <Binding Path="PrepTimeMinutes" />
                                                    </MultiBinding>
                                                </Label.Text>
                                            </Label>
                                            <Label Text="·" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}"
                                                   Text="{Binding Calories, StringFormat='{0} cal'}" />
                                            <Label Text="·" FontSize="13" TextColor="{StaticResource TextTertiary}" />
                                            <Label FontSize="13" TextColor="{StaticResource TextSecondary}"
                                                   Text="{Binding Difficulty}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToRecipeDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
        </RefreshView>

        <!-- Shake Result Overlay -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding HasShakeResult}"
              BackgroundColor="#80000000" ZIndex="100">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding DismissShakeResultCommand}" />
            </Grid.GestureRecognizers>
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}"
                    Padding="0" Margin="32" VerticalOptions="Center"
                    HorizontalOptions="Center" WidthRequest="300">
                <Border.Shadow>
                    <Shadow Brush="#40000000" Offset="0,8" Radius="20" Opacity="0.5" />
                </Border.Shadow>
                <VerticalStackLayout>
                    <Image Source="{Binding ShakeResult.ImageUrl}"
                           HeightRequest="180" Aspect="AspectFill" />
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                        <Label Text="{Binding ShakeResult.Name}" FontSize="16"
                               FontAttributes="Bold" VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#EBE8E0}" />
                        <Button Grid.Column="1" Text="×" FontSize="20"
                                TextColor="{StaticResource TextTertiary}"
                                BackgroundColor="Transparent" Padding="8,0"
                                Command="{Binding DismissShakeResultCommand}" />
                    </Grid>
                    <Label Padding="16,0,16,4" FontSize="12"
                           TextColor="{StaticResource TextSecondary}"
                           Text="{Binding ShakeResult.Description}"
                           LineBreakMode="TailTruncation" MaxLines="2" />
                    <Button Text="View Recipe" Style="{StaticResource PrimaryButton}"
                            Margin="16,10,16,16"
                            Command="{Binding ViewShakeResultCommand}"
                            SemanticProperties.Description="View the randomly selected recipe" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
