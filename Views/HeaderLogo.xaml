<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TastyMealPlanner.Views.HeaderLogo">
    <VerticalStackLayout Spacing="0">
        <Grid ColumnDefinitions="*,Auto" Padding="16,14,12,12"
              BackgroundColor="{AppThemeBinding Light=#FEF7F0, Dark=#1E1C18}">
            <VerticalStackLayout Grid.Column="0" Spacing="0">
                <Label Text="Nosh Your Nosh" FontSize="30"
                       FontFamily="Pacifico"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#EBE8E0}"
                       SemanticProperties.Description="Nosh Your Nosh home">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="Discover what to cook today" FontSize="11"
                       TextColor="{StaticResource TextTertiary}" Margin="2,0,0,0" />
            </VerticalStackLayout>
        </Grid>
        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E8E3DC, Dark=#2C2C28}" />
    </VerticalStackLayout>
</ContentView>
