<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             x:Class="TastyMealPlanner.Views.MealPlanPage"
             x:DataType="vm:MealPlanViewModel"
             Title="Meal Plan"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,*" Padding="0">
        <Label Grid.Row="0" Text="This Week" FontSize="18" FontAttributes="Bold"
               Padding="16,12"
               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding WeekPlan}"
                        Margin="8,0,8,16">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label Text="No meals planned yet" FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Text="Browse recipes to add meals" FontSize="13"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextTertiary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:DayPlanGroup">
                    <VerticalStackLayout Margin="0,0,0,12">
                        <!-- Day Header -->
                        <Label Text="{Binding DayName}" FontSize="13" FontAttributes="Bold"
                               Padding="4,8,0,6"
                               TextColor="{StaticResource TextTertiary}" />

                        <!-- Meals for this day -->
                        <CollectionView ItemsSource="{Binding Entries}" HeightRequest="130">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.EmptyView>
                                <Label Text="No meals planned" FontSize="12"
                                       TextColor="{StaticResource TextTertiary}"
                                       VerticalTextAlignment="Center" Margin="8,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:MealPlanEntry">
                                    <Border StrokeShape="RoundRectangle 12"
                                            Stroke="{AppThemeBinding Light={StaticResource Light_Border}, Dark={StaticResource Dark_Border_Alt}}"
                                            StrokeThickness="1" Padding="0"
                                            WidthRequest="150"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                        <VerticalStackLayout>
                                            <Image Source="{Binding Recipe.ImageUrl}"
                                                   HeightRequest="90" Aspect="AspectFill" />
                                            <VerticalStackLayout Padding="10,8" Spacing="2">
                                                <Label Text="{Binding MealType}" FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Accent}" />
                                                <Label Text="{Binding Recipe.Name}" FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=RemoveMealCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
