<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.MealPlanPage"
             x:DataType="vm:MealPlanViewModel"
             Shell.NavBarIsVisible="False" Title="Meal Plan"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="0" RowSpacing="0">
        <!-- Row 0: Header/Logo -->
        <views:HeaderLogo Grid.Row="0" />

        <!-- Row 1: Week navigation bar -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Padding="16,10" ColumnSpacing="8">
            <!-- Previous week -->
            <Button Grid.Column="0" Text="❮" FontSize="22"
                    Command="{Binding GoToPreviousWeekCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Accent}"
                    WidthRequest="40" HeightRequest="40"
                    Padding="0" HorizontalOptions="Start" VerticalOptions="Center" />

            <!-- Week label + Today button -->
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center"
                                 VerticalOptions="Center" Spacing="6">
                <Label Text="{Binding WeekLabel}" FontSize="15" FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary},
                                                  Dark={StaticResource Dark_TextPrimary_Alt}}" />
                <Button Text="{Binding TodayLabel}" FontSize="11" Padding="10,3" CornerRadius="6"
                        Command="{Binding BackToCurrentWeekCommand}"
                        IsVisible="{Binding ShowBackToCurrent}"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White" HeightRequest="26"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Next week -->
            <Button Grid.Column="2" Text="❯" FontSize="22"
                    Command="{Binding GoToNextWeekCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Accent}"
                    WidthRequest="40" HeightRequest="40"
                    Padding="0" HorizontalOptions="End" VerticalOptions="Center" />
        </Grid>

        <!-- Row 2: Day strip (centered, equally spaced) -->
        <FlexLayout Grid.Row="2" Direction="Row" JustifyContent="SpaceEvenly"
                    AlignItems="Center" Padding="8,4" HeightRequest="86"
                    BindableLayout.ItemsSource="{Binding DayStrip}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:DayStripItem">
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1.5"
                            Padding="6,8"
                            Stroke="{AppThemeBinding Light=#E8E3DC, Dark=#33312D}"
                            BackgroundColor="Transparent"
                            WidthRequest="46" HeightRequest="74">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light=#20FF6B35, Dark=#30FF6B35}" />
                            </DataTrigger>
                            <MultiTrigger TargetType="Border">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsToday}" Value="True" />
                                    <BindingCondition Binding="{Binding IsSelected}" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light=#10FF6B35, Dark=#15FF6B35}" />
                            </MultiTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding DayAbbr}" FontSize="11"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding DateNumber}" FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary},
                                                              Dark={StaticResource Dark_TextPrimary_Alt}}" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=SelectDayCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>

        <!-- Row 3: Divider -->
        <BoxView Grid.Row="3" HeightRequest="1"
                 Color="{AppThemeBinding Light=#E8E3DC, Dark=#2A2A25}"
                 Margin="16,0" />

        <!-- Row 4: Selected day detail with RefreshView -->
        <RefreshView Grid.Row="4" Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <Grid RowDefinitions="Auto,*" Padding="16,8" RowSpacing="0">
                <!-- Selected day header -->
                <VerticalStackLayout Grid.Row="0" Spacing="2" Padding="0,8,0,12">
                    <Label Text="{Binding SelectedDayHeader}" FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary},
                                                      Dark={StaticResource Dark_TextPrimary_Alt}}" />
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="{Binding MealCountLabel}" FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalTextAlignment="Center" />
                        <Button Text="+ Add" FontSize="11" Padding="10,3"
                                CornerRadius="6" HeightRequest="26"
                                Command="{Binding AddMealCommand}"
                                BackgroundColor="{StaticResource Accent}"
                                TextColor="White" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Meal list -->
                <CollectionView Grid.Row="1" ItemsSource="{Binding SelectedDayMeals}"
                                Margin="0,0,0,16">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="8" Padding="0,60">
                            <Label Text="No meals planned" FontSize="16"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="Tap + Add to browse recipes"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource TextTertiary}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MealPlanEntry">
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="{AppThemeBinding Light=#E8E3DC, Dark=#33312D}"
                                    StrokeThickness="1" Padding="14,12"
                                    Margin="0,5"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White},
                                                                     Dark={StaticResource Dark_Card}}">
                                <Border.Shadow>
                                    <Shadow Brush="#15000000" Offset="0,2"
                                            Radius="6" Opacity="0.2" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12">
                                    <!-- Meal type badge -->
                                    <Border Grid.Column="0" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{StaticResource Accent}"
                                            Padding="10,5" VerticalOptions="Center">
                                        <Label Text="{Binding MealType}" FontSize="10"
                                               TextColor="White"
                                               FontAttributes="Bold" />
                                    </Border>
                                    <!-- Recipe name -->
                                    <Label Grid.Column="1"
                                           Text="{Binding Recipe.Name}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary},
                                                                      Dark={StaticResource Dark_TextPrimary_Alt}}"
                                           VerticalTextAlignment="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                    <!-- Remove button -->
                                    <Border Grid.Column="2" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            BackgroundColor="{StaticResource Error}"
                                            WidthRequest="28" HeightRequest="28"
                                            Padding="0" VerticalOptions="Center">
                                        <Label Text="✕" FontSize="12"
                                               TextColor="White"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=RemoveMealCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=NavigateToDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>
    </Grid>

</ContentPage>
