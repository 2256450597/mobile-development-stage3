<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.MealPlanPage"
             x:DataType="vm:MealPlanViewModel"
             Shell.NavBarIsVisible="False" Title="Meal Plan"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">
        <views:HeaderLogo Grid.Row="0" />

        <Label Grid.Row="1" Text="Week Plan" FontSize="18" FontAttributes="Bold"
               Padding="16,12"
               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />

        <RefreshView Grid.Row="2" IsRefreshing="{Binding IsBusy}">
        <CollectionView ItemsSource="{Binding WeekPlan}" Margin="8,0,8,16">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label Text="No meals planned yet" FontSize="16"
                           HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    <Label Text="Browse recipes to add meals" FontSize="13"
                           HorizontalTextAlignment="Center" TextColor="{StaticResource TextTertiary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:DayPlanGroup">
                    <!-- Newspaper column style: alternating cream/white backgrounds -->
                    <Grid RowDefinitions="Auto,Auto" Padding="0"
                          BackgroundColor="{AppThemeBinding Light=#FDFBF7, Dark=#1A1A17}">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="False">
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light=#FFFFFF, Dark=#141412}" />
                            </DataTrigger>
                        </Grid.Triggers>

                        <!-- Day header row -->
                        <Grid ColumnDefinitions="*,Auto" Padding="16,10,16,8">
                            <Label Text="{Binding DayName}" FontSize="14"
                                   FontAttributes="Bold"
                                   CharacterSpacing="2"
                                   TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#C8B8A0}"
                                   VerticalTextAlignment="Center" />
                            <Button Grid.Column="1" Text="+ Add"
                                    FontSize="10" Padding="10,2" CornerRadius="2"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource TextTertiary}"
                                    BorderColor="{StaticResource TextTertiary}"
                                    BorderWidth="1" HeightRequest="26"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=AddMealCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>

                        <!-- Divider line -->
                        <BoxView HeightRequest="1"
                                 Color="{AppThemeBinding Light=#D5CFC5, Dark=#33312D}"
                                 Margin="16,0,16,0" />

                        <!-- Meal cards row -->
                        <CollectionView Grid.Row="1" ItemsSource="{Binding Entries}"
                                        HeightRequest="130" Margin="12,10,12,12">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.EmptyView>
                                <Label Text="No meals planned"
                                       FontSize="11" TextColor="{StaticResource TextTertiary}"
                                       VerticalTextAlignment="Center" Margin="8,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:MealPlanEntry">
                                    <Border StrokeShape="RoundRectangle 2"
                                            Stroke="{AppThemeBinding Light=#D5CFC5, Dark=#3A3530}"
                                            StrokeThickness="1" Padding="0"
                                            WidthRequest="130"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                        <Border.Shadow>
                                            <Shadow Brush="#08000000" Offset="0,1" Radius="3" Opacity="0.3" />
                                        </Border.Shadow>
                                        <VerticalStackLayout>
                                            <Image Source="{Binding Recipe.ImageUrl}"
                                                   HeightRequest="85" Aspect="AspectFill" />
                                            <VerticalStackLayout Padding="8,6" Spacing="2">
                                                <Label Text="{Binding MealType}" FontSize="9"
                                                       FontAttributes="Bold"
                                                       CharacterSpacing="1.5"
                                                       TextColor="{StaticResource Accent}" />
                                                <Label Text="{Binding Recipe.Name}" FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=NavigateToDetailCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
