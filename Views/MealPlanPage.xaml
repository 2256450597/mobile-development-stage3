<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TastyMealPlanner.ViewModels"
             xmlns:models="clr-namespace:TastyMealPlanner.Models"
             xmlns:views="clr-namespace:TastyMealPlanner.Views"
             x:Class="TastyMealPlanner.Views.MealPlanPage"
             x:DataType="vm:MealPlanViewModel"
             Shell.NavBarIsVisible="False" Title="Meal Plan"
             BackgroundColor="{AppThemeBinding Light={StaticResource Light_Background}, Dark={StaticResource Dark_Background}}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">
        <views:HeaderLogo Grid.Row="0" />

        <Label Grid.Row="1" Text="This Week" FontSize="18" FontAttributes="Bold"
               Padding="16,12"
               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}" />

        <RefreshView Grid.Row="2" IsRefreshing="{Binding IsBusy}">
        <CollectionView ItemsSource="{Binding WeekPlan}" Margin="8,0,8,16">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label Text="No meals planned yet" FontSize="16"
                           HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    <Label Text="Browse recipes to add meals" FontSize="13"
                           HorizontalTextAlignment="Center" TextColor="{StaticResource TextTertiary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:DayPlanGroup">
                    <!-- Notepad-style day card -->
                    <Border Margin="8,4,8,12" Padding="0"
                            StrokeShape="RoundRectangle 6"
                            Stroke="{AppThemeBinding Light=#E0D8CC, Dark=#3A3530}"
                            StrokeThickness="1">
                        <Grid>
                            <Image Source="notepad_bg.jpg" Aspect="AspectFill" Opacity="0.2" />
                            <VerticalStackLayout>
                                <Grid ColumnDefinitions="*,Auto" Padding="12,10,12,6">
                                    <Label Text="{Binding DayName}" FontSize="13" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#5C4A3A, Dark=#C8B8A0}"
                                           VerticalTextAlignment="Center" />
                                    <Button Grid.Column="1" Text="+ Add" FontSize="11"
                                            Padding="10,4" CornerRadius="4"
                                            BackgroundColor="{StaticResource Accent}" TextColor="White"
                                            HeightRequest="30"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=AddMealCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E8E0D0, Dark=#2C2820}"
                                         Margin="12,0,12,0" />
                                <CollectionView ItemsSource="{Binding Entries}" HeightRequest="130"
                                                Margin="8,8,8,12">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.EmptyView>
                                        <Label Text="No meals planned" FontSize="12"
                                               TextColor="{StaticResource TextTertiary}"
                                               VerticalTextAlignment="Center" Margin="8,0" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:MealPlanEntry">
                                            <Border StrokeShape="RoundRectangle 6"
                                                    Stroke="{AppThemeBinding Light=#E8E0D0, Dark=#3A3530}"
                                                    StrokeThickness="1" Padding="0"
                                                    WidthRequest="140"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Dark_Card}}">
                                                <VerticalStackLayout>
                                                    <Image Source="{Binding Recipe.ImageUrl}"
                                                           HeightRequest="85" Aspect="AspectFill" />
                                                    <VerticalStackLayout Padding="8,6" Spacing="2">
                                                        <Label Text="{Binding MealType}" FontSize="10"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource Accent}" />
                                                        <Label Text="{Binding Recipe.Name}" FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource Light_TextPrimary}, Dark={StaticResource Dark_TextPrimary_Alt}}"
                                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                                    </VerticalStackLayout>
                                                </VerticalStackLayout>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanViewModel}}, Path=NavigateToDetailCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
